@page "/"

<PageTitle>Currículo | Dev .NET</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4">
            <div class="text-center p-4 bg-light rounded-3 mb-4">
                <img src="https://static.tvtropes.org/pmwiki/pub/images/abcb6534_7913_4eb1_a7a5_62b081ebc628.png"
                     class="rounded-circle mb-3" width="120" />
                <h3>Christopher Azevedo</h3>
                <p class="text-muted">Cientista de Dados</p>
            </div>
        </div>

        <div class="col-lg-8">
            <h2 class="mb-4">Experiência Profissional</h2>
            
            @foreach (var exp in MinhasExperiencias)
            {
                <ExperienciaCard Dados="exp" />
            }
        </div>
    </div>
</div>

@code {
    private List<Experiencia> MinhasExperiencias = new()
    {
        new Experiencia {
            Empresa = "Instituto Hermes Pardini",
            Cargo = "Atendente",
            Inicio = "2026", Fim = "Atual",
            Descricao = "Atendimento à clientes, lançamento de exames e administração dos dados da empresa."
        },
        new Experiencia {
            Empresa = "Instituto Hermes Pardini",
            Cargo = "Aprendiz",
            Inicio = "2025", Fim = "2026",
            Descricao = "Atendimento de primeira triagem aos clientes, e uso do sistema interno da empresa."
        }
    };
}